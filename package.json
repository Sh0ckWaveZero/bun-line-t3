{
  "name": "bun-line-t3",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:push": "prisma db push",
    "db:studio": "bunx prisma studio",
    "dev": "vite dev --port 4325 --host localhost",
    "postinstall": "if [ \"${SKIP_PRISMA_GENERATE:-0}\" != \"1\" ]; then bunx prisma generate --no-hints; fi",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "vite preview --port 4325 --host localhost",
    "start:prod": "bun server.ts",
    "tailwind:build": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css",
    "tailwind:watch": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:timezone": "bun test timezone",
    "test:line": "bun test tests/line-timezone.test.ts",
    "test:skip": "echo 'Tests skipped - use bun run test for local testing'",
    "type-check": "tsc --noEmit",
    "env:dev": "./scripts/devops/switch-env.sh dev",
    "env:prod": "./scripts/devops/switch-env.sh prod",
    "env:status": "./scripts/devops/switch-env.sh status",
    "debug:line-oauth": "echo 'Open http://localhost:4325/line-oauth-debug in your browser'",
    "seed:admin": "bun scripts/db/seed-admin-roles.ts",
    "db:check-indexes": "bun scripts/db/check-indexes.ts",
    "db:create-indexes": "bun scripts/db/create-missing-indexes.ts",
    "db:delete-old-accounts": "bun scripts/db/delete-old-line-accounts.ts",
    "db:update-holidays": "bun scripts/db/update-holiday-notifications.ts",
    "migrate:user-settings": "bun scripts/migrations/migrate-user-settings.ts",
    "migrate:better-auth": "bun scripts/migrations/migrate-better-auth-canonical.ts",
    "migrate:mongo-to-pg": "bun scripts/migrations/migrate-mongodb-to-postgres.ts",
    "migrate:mongo-to-pg:dry": "DRY_RUN=1 bun scripts/migrations/migrate-mongodb-to-postgres.ts",
    "generate:secrets": "bun scripts/secrets/generate-secrets.ts",
    "secrets:generate": "bun scripts/secrets/generate-github-secrets.ts generate",
    "secrets:info": "bun scripts/secrets/generate-github-secrets.ts info",
    "secrets:validate": "bun scripts/secrets/generate-github-secrets.ts validate",
    "health:check": "./scripts/monitoring/health-check.sh",
    "health:monitoring": "./scripts/monitoring/monitoring-dashboard.sh",
    "health:line-oauth": "./scripts/monitoring/check-line-oauth.sh",
    "health:proxy": "./scripts/monitoring/check-proxy-headers.sh",
    "docker:optimize": "./scripts/devops/optimize-bundle.sh",
    "runner:monitor": "./monitor-runner.sh",
    "docker:cleanup": "docker system prune -f && docker image prune -a -f",
    "deploy:check": "bun scripts/generate-github-secrets.ts validate && docker system info"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
