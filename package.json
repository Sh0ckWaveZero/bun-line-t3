{
  "name": "bun-line-t3",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:deploy": "prisma db push && prisma generate",
    "db:studio": "bunx prisma studio",
    "dev": "vite dev --port 4325 --host localhost",
    "postinstall": "bunx prisma generate",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "vite preview --port 4325 --host localhost",
    "start:prod": "bun dist/server/server.js",
    "tailwind:build": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css",
    "tailwind:watch": "bunx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:timezone": "bun test timezone",
    "test:line": "bun test tests/line-timezone.test.ts",
    "test:skip": "echo 'Tests skipped - use bun run test for local testing'",
    "type-check": "tsc --noEmit",
    "env:dev": "./scripts/switch-env.sh dev",
    "env:prod": "./scripts/switch-env.sh prod",
    "env:status": "./scripts/switch-env.sh status",
    "debug:line-oauth": "echo 'Open http://localhost:4325/line-oauth-debug in your browser'",
    "seed:holidays": "tsx scripts/seed-holidays-2025.ts",
    "migrate:user-settings": "bun scripts/migrate-user-settings.ts",
    "generate:secrets": "bun scripts/generate-secrets.ts",
    "secrets:generate": "bun scripts/generate-github-secrets.ts generate",
    "secrets:info": "bun scripts/generate-github-secrets.ts info",
    "secrets:validate": "bun scripts/generate-github-secrets.ts validate",
    "runner:monitor": "./monitor-runner.sh",
    "docker:cleanup": "docker system prune -f && docker image prune -a -f",
    "deploy:check": "bun scripts/generate-github-secrets.ts validate && docker system info"
  },
