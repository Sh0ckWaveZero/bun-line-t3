# =============================================================================
# Environment Configuration
# =============================================================================

# Application Environment
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
HOSTNAME=localhost
PORT=4325
FRONTEND_URL=

# 🌐 Domain Configuration | การกำหนดค่า Domain
# ⚠️ REQUIRED: ต้องตั้งค่าใน environment - ไม่มี default values
# ❗ SECURITY: ห้าม hardcode ใน schema - ต้องกำหนดค่าชัดเจนใน .env
APP_DOMAIN=https://your-app.example.com

# 🛡️ Security: รายชื่อ domain ที่อนุญาต (คั่นด้วยจุลภาค)
# ❗ REQUIRED: ต้องระบุอย่างน้อย 1 domain
ALLOWED_DOMAINS=your-app.example.com,example.com

# 📝 Usage Examples | ตัวอย่างการใช้งาน:
# - Development: APP_DOMAIN=http://localhost:4325
# - Staging: APP_DOMAIN=https://staging.example.com
# - Production: APP_DOMAIN=https://your-app.example.com

# 🔒 Security Benefits | ประโยชน์ด้านความปลอดภัย:
# ✅ ไม่ hardcode domain ในโค้ด
# ✅ ปรับเปลี่ยน domain ได้ตาม environment
# ✅ ลดความเสี่ยงในการ deployment
# ✅ รองรับการพัฒนาแบบ multi-environment

# =============================================================================
# Authentication & Security
# =============================================================================

# Better Auth Configuration
APP_URL=
AUTH_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=

# Internal API Security (Generate a secure random string)
INTERNAL_API_KEY=

# Cron Job Security (Generate a secure random string)
CRON_SECRET=

# =============================================================================
# LINE Integration
# =============================================================================

# LINE Login Provider
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# LINE Messaging API
LINE_CHANNEL_ACCESS=
LINE_MESSAGING_API=https://api.line.me/v2/bot/message
LINE_GET_CONTENT=https://api-data.line.me/v2/bot/message
LINE_CHANNEL_SECRET=

# =============================================================================
# Database Configuration
# =============================================================================

# MongoDB
MONGODB_URI=
DATABASE_URL=
DB_NAME=

# =============================================================================
# External API Keys
# =============================================================================

# Air Quality Monitoring
AIRVISUAL_API_KEY=
IQAIR_KEY=

# Cryptocurrency Market Data
CMC_API_KEY=
CMC_URL=https://pro-api.coinmarketcap.com

# OpenAI API (Required for AI Assistant)
OPENAI_API_KEY=

# AI Assistant Configuration
# Direct OpenAI API integration (no MCP server needed)
# Supported models: gpt-5-nano, gpt-4o, gpt-4-turbo, gpt-3.5-turbo, or any OpenAI model
# Default: gpt-5-nano (recommended for cost/performance balance)
MCP_AI_MODEL=gpt-5-nano

# Other APIs
X_APT_KEY=
