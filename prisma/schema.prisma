// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Better Auth core models
model Account {
  id                     String    @id @default(cuid())
  accountId              String
  providerId             String
  userId                 String
  accessToken            String?
  refreshToken           String?
  idToken                String?
  accessTokenExpiresAt   DateTime?
  refreshTokenExpiresAt  DateTime?
  scope                  String?
  password               String?
  // LINE-specific fields for separating Login and Messaging API user IDs
  lineMessagingApiUserId String?   @unique @map("line_messaging_api_user_id")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([lineMessagingApiUserId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  emailVerified     Boolean           @default(false)
  image             String?
  role              String            @default("user")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  accounts          Account[]
  sessions          Session[]
  workAttendances   WorkAttendance[]
  leaves            Leave[]
  settings          UserSettings?
  expenseCategories     ExpenseCategory[]
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  savingsGoals          SavingsGoal[]

  @@map("users")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

enum AttendanceStatusType {
  CHECKED_IN_ON_TIME
  CHECKED_IN_LATE
  CHECKED_OUT
  AUTO_CHECKOUT_MIDNIGHT
  LEAVE
}

model Cmc {
  id        String   @id @default(cuid())
  no        Int
  name      String
  symbol    String
  slug      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("cmc")
}

model WorkAttendance {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  checkInTime       DateTime             @map("check_in_time")
  checkOutTime      DateTime?            @map("check_out_time")
  workDate          String               @map("work_date") // YYYY-MM-DD format
  status            AttendanceStatusType @default(CHECKED_IN_ON_TIME)
  hoursWorked       Float?               @map("hours_worked")
  leaveId           String?              @map("leave_id")
  // Checkout reminder tracking
  reminderSent10Min Boolean              @default(false) @map("reminder_sent_10min")
  reminderSentFinal Boolean              @default(false) @map("reminder_sent_final")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leave             Leave?               @relation(fields: [leaveId], references: [id])

  @@unique([userId, workDate])
  @@map("work_attendance")
}

model PublicHoliday {
  id          String   @id @default(cuid())
  date        String   @unique @map("date") // YYYY-MM-DD format
  nameEnglish String   @map("name_english")
  nameThai    String   @map("name_thai")
  year        Int      @map("year")
  type        String   @default("national") @map("type")
  isActive    Boolean  @default(true) @map("is_active")
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([year, isActive])
  @@index([date, isActive])
  @@map("public_holidays")
}

model Leave {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  date            String           @map("date") // YYYY-MM-DD
  type            String           @default("personal")
  reason          String?          @map("reason")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workAttendances WorkAttendance[]

  @@index([userId, date, isActive])
  @@map("leaves")
}

model UserSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique @map("user_id")
  // Notification preferences
  enableCheckInReminders     Boolean  @default(true) @map("enable_checkin_reminders")
  enableCheckOutReminders    Boolean  @default(true) @map("enable_checkout_reminders")
  enableHolidayNotifications Boolean  @default(false) @map("enable_holiday_notifications")
  // Privacy — ซ่อนจำนวนเงินใน LINE Messaging API
  hideAmountsLinePersonal    Boolean  @default(false) @map("hide_amounts_line_personal")
  hideAmountsLineGroup       Boolean  @default(false) @map("hide_amounts_line_group")
  // Privacy — ซ่อนจำนวนเงินบนหน้าเว็บ
  hideAmountsWeb             Boolean  @default(false) @map("hide_amounts_web")
  // Timezone and locale
  timezone                   String   @default("Asia/Bangkok") @map("timezone")
  language                   String   @default("th") @map("language")
  // Timestamps
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  // Relations
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ===========================
// Subscription Tracker
// ===========================

enum SubscriptionService {
  YOUTUBE
  YOUTUBE_MUSIC
  SPOTIFY
  APPLE_MUSIC
  NETFLIX
  APPLE_TV
  HBO_MAX
  TWITCH
  STEAM
  PLAYSTATION
  ICLOUD
  LINE
  GOOGLE_TV
  OTHER
}

enum SubscriptionPlanType {
  INDIVIDUAL
  FAMILY
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  SKIPPED
}

model Subscription {
  id           String                @id @default(cuid())
  name         String                @map("name")
  service      SubscriptionService   @map("service")
  planType     SubscriptionPlanType  @default(INDIVIDUAL) @map("plan_type")
  billingCycle BillingCycle          @default(MONTHLY) @map("billing_cycle")
  totalPrice   Float                 @map("total_price")
  currency     String                @default("THB") @map("currency")
  billingDay   Int                   @map("billing_day")
  ownerId      String                @map("owner_id")
  isActive     Boolean               @default(true) @map("is_active")
  startDate    DateTime              @map("start_date")
  endDate      DateTime?             @map("end_date")
  logoUrl      String?               @map("logo_url")
  note         String?               @map("note")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  members      SubscriptionMember[]
  payments     SubscriptionPayment[]

  @@index([ownerId, isActive])
  @@index([service, isActive])
  @@map("subscriptions")
}

model SubscriptionMember {
  id             String                @id @default(cuid())
  subscriptionId String                @map("subscription_id")
  userId         String?               @map("user_id")
  name           String                @map("name")
  email          String?               @map("email")
  shareAmount    Float                 @map("share_amount")
  isActive       Boolean               @default(true) @map("is_active")
  joinedAt       DateTime              @default(now()) @map("joined_at")
  leftAt         DateTime?             @map("left_at")
  note           String?               @map("note")
  tags           String?               @map("tags")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments       SubscriptionPayment[]

  @@index([subscriptionId, isActive])
  @@map("subscription_members")
}

model SubscriptionPayment {
  id             String             @id @default(cuid())
  subscriptionId String             @map("subscription_id")
  memberId       String             @map("member_id")
  billingMonth   String             @map("billing_month") // YYYY-MM format
  amount         Float              @map("amount")
  status         PaymentStatus      @default(PENDING) @map("status")
  paidAt         DateTime?          @map("paid_at")
  dueDate        DateTime           @map("due_date")
  paidBy         String?            @map("paid_by")
  note           String?            @map("note")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  member         SubscriptionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, billingMonth])
  @@index([subscriptionId, billingMonth])
  @@index([memberId, status])
  @@index([billingMonth, status])
  @@map("subscription_payments")
}

enum ActivityType {
  WALKING
  RUNNING
  CYCLING
  SWIMMING
  WORKOUT
  YOGA
  OTHER
}

model HealthActivity {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  activityType ActivityType @map("activity_type")
  date         DateTime     @map("date")
  duration     Float        @map("duration") // in minutes
  distance     Float?       @map("distance") // in kilometers
  calories     Float?       @map("calories")
  steps        Int?         @map("steps")
  heartRate    Json?        @map("heart_rate") // { average, max, min }
  metadata     Json?        @map("metadata")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([userId, date])
  @@index([userId, activityType])
  @@map("health_activities")
}

model HealthMetrics {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  date             DateTime @map("date")
  weight           Float?   @map("weight") // in kg
  height           Float?   @map("height") // in cm
  bmi              Float?   @map("bmi")
  bodyFat          Float?   @map("body_fat") // percentage
  bloodPressure    Json?    @map("blood_pressure") // { systolic, diastolic }
  restingHeartRate Int?     @map("resting_heart_rate")
  sleepHours       Float?   @map("sleep_hours")
  waterIntake      Float?   @map("water_intake") // in liters
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("health_metrics")
}

// ===========================
// Auto DCA (Dollar Cost Averaging)
// ===========================

enum DcaStatus {
  SUCCESS
  FAILED
  PENDING
}

model DcaOrder {
  id           String    @id @default(cuid())
  orderId      String    @map("order_id")
  lineUserId   String    @map("line_user_id")
  coin         String    @default("BTC") @map("coin")
  amountTHB    Float     @map("amount_thb")
  coinReceived Float     @map("coin_received")
  pricePerCoin Float     @map("price_per_coin")
  round        Int       @map("round")
  status       DcaStatus @default(SUCCESS) @map("status")
  note         String?   @map("note")
  executedAt   DateTime  @map("executed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([lineUserId, coin, executedAt])
  @@index([orderId])
  @@index([lineUserId, executedAt])
  @@index([coin, executedAt])
  @@index([round])
  @@map("dca_orders")
}

// ===========================
// Expense Tracker (รายรับรายจ่าย)
// ===========================

enum TransactionType {
  INCOME // รายรับ
  EXPENSE // รายจ่าย
}

model ExpenseCategory {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  name         String        @map("name")
  icon         String?       @map("icon") // emoji หรือ icon name
  color        String?       @map("color") // hex color
  isDefault    Boolean       @default(false) @map("is_default")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  @@unique([userId, name])
  @@index([userId, isActive])
  @@map("expense_categories")
}

model Transaction {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  categoryId String          @map("category_id")
  type       TransactionType @map("type")
  amount     Float           @map("amount") // จำนวนเงิน (THB)
  note       String?         @map("note") // หมายเหตุ
  tags       String?         @map("tags") // comma-separated tags
  transDate  String          @map("trans_date") // YYYY-MM-DD
  transMonth String          @map("trans_month") // YYYY-MM (index ด้วย)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, transMonth])
  @@index([userId, type, transMonth])
  @@index([categoryId])
  @@map("transactions")
}

// ===========================
// Budget (งบประมาณรายเดือนต่อหมวดหมู่)
// ===========================

model Budget {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  categoryId String?         @map("category_id") // null = งบรวมทุกหมวด
  type       TransactionType @default(EXPENSE) @map("type")
  amount     Float           @map("amount") // จำนวนเงินงบ (THB/เดือน)
  alertAt    Int             @default(80) @map("alert_at") // แจ้งเตือนเมื่อใช้ถึง % นี้
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId]) // 1 budget ต่อ category ต่�� user
  @@index([userId, isActive])
  @@map("budgets")
}

// ===========================
// Recurring Transaction (รายการประจำ)
// ===========================

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model RecurringTransaction {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  categoryId  String             @map("category_id")
  type        TransactionType    @map("type")
  amount      Float              @map("amount")
  note        String?            @map("note")
  tags        String?            @map("tags")
  frequency   RecurringFrequency @map("frequency")
  dayOfMonth  Int?               @map("day_of_month") // วันที่ในเดือน (1-31) สำหรับ MONTHLY
  dayOfWeek   Int?               @map("day_of_week") // วันในสัปดาห์ (0=อาทิตย์) สำหรับ WEEKLY
  nextRunDate String             @map("next_run_date") // YYYY-MM-DD ถัดไปที่จะสร้าง transaction
  lastRunDate String?            @map("last_run_date") // YYYY-MM-DD ครั้งล่าสุดที่สร้าง
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    ExpenseCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([isActive, nextRunDate])
  @@index([userId, isActive])
  @@map("recurring_transactions")
}

// ===========================
// Savings Goal (เป้าหมายการออม)
// ===========================

model SavingsGoal {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String   @map("name") // ชื่อเป้าหมาย เช่น "ซื้อ iPhone", "เที่ยวญี่ปุ่น"
  icon         String?  @map("icon") // emoji
  targetAmount Float    @map("target_amount") // เป้าหมาย (บาท)
  savedAmount  Float    @default(0) @map("saved_amount") // ออมแล้ว (บาท)
  deadline     String?  @map("deadline") // YYYY-MM-DD
  isCompleted  Boolean  @default(false) @map("is_completed")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("savings_goals")
}

// ===========================
// LINE Messaging API Approval
// ===========================

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model LineApprovalRequest {
  id              String         @id @default(cuid())
  lineUserId      String         @unique @map("line_user_id")
  loginLineUserId String?        @unique @map("login_line_user_id")
  displayName     String?        @map("display_name")
  pictureUrl      String?        @map("picture_url")
  statusMessage   String?        @map("status_message")
  reason          String?        @map("reason")
  rejectReason    String?        @map("reject_reason")
  status          ApprovalStatus @default(PENDING) @map("status")
  approvedBy      String?        @map("approved_by")
  approvedAt      DateTime?      @map("approved_at")
  expiresAt       DateTime?      @map("expires_at")
  notifiedAt      DateTime?      @map("notified_at")

  // Feature permissions
  canRequestAttendanceReport Boolean @default(false) @map("can_request_attendance_report")
  canRequestLeave            Boolean @default(false) @map("can_request_leave")
  canReceiveReminders        Boolean @default(false) @map("can_receive_reminders")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([lineUserId, status])
  @@map("line_approval_requests")
}
