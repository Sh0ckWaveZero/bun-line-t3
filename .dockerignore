# Docker Build Optimization - Ignore List
# Reduces build context size and improves build speed

# =============================================================================
# Version Control
# =============================================================================
.git
.gitignore
.gitattributes

# =============================================================================
# Dependencies (will be installed fresh in container)
# =============================================================================
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun.lockb.backup*

# =============================================================================
# Prisma (will be generated in container)
# =============================================================================
node_modules/.prisma/
node_modules/@prisma/engines/
# Note: Keep prisma/ folder - schema.prisma is needed
# Note: migrations/ excluded for MongoDB (no migrations)
prisma/migrations/

# =============================================================================
# Build Outputs (will be built in container)
# =============================================================================
.next/
out/
build/
dist/
src/output.css

# =============================================================================
# Testing
# =============================================================================
*.test.js
*.test.ts
*.spec.js
*.spec.ts
__tests__/
coverage/
.nyc_output
junit.xml
tests/

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.agent/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
logs/

# =============================================================================
# Documentation (not needed at runtime)
# =============================================================================
README.md
CHANGELOG.md
LICENSE
*.md
docs/
GEMINI.md
CLAUDE.md

# =============================================================================
# Development Config
# =============================================================================
.eslintrc*
eslint.config.*
.prettierrc*
prettier.config.*
.babelrc*
jest.config.*
vitest.config.*
cypress/
.storybook/
stories/
tsconfig.*.json
!tsconfig.json

# =============================================================================
# Docker (prevent recursive copy)
# =============================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# =============================================================================
# CI/CD & Deployment
# =============================================================================
.vercel
.netlify
.github/
.gitlab-ci.yml
.travis.yml

# =============================================================================
# Security - Certificates & Keys
# =============================================================================
certificates/
*.pem
*.key
*.crt
*.p12
*.pfx

# =============================================================================
# Scripts (keep only essential startup scripts)
# =============================================================================
scripts/
!scripts/devops/docker-entrypoint.sh
!scripts/monitoring/health-check.sh
!scripts/devops/cron-request.sh

# =============================================================================
# Database Files
# =============================================================================
*.db
*.sqlite
*.sqlite3
migration-*.sql

# =============================================================================
# Environment Files
# =============================================================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production.local
.env.*.local
!.env.example

# =============================================================================
# Temporary & Cache
# =============================================================================
*.tmp
*.temp
.tmp/
temp/
.cache/
.parcel-cache/
.nuxt/
.output/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.locks/

# =============================================================================
# Package Manager Locks (keep bun.lock only)
# =============================================================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Misc
# =============================================================================
Makefile
*.tgz
*.tar.gz
*.zip
public/temp-charts/*
